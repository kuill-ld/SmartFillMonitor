<UserControl x:Class="SmartFillMonitor.Views.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="20" HorizontalAlignment="Left" Width="800">
            <Border Margin="0,0,0,10" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="通信参数设置" Foreground="Red" FontSize="14" Margin="0,0,0,10"/>
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="串口号" Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Foreground="White"/>
                        <ComboBox Grid.Row="0" SelectedItem="{Binding SelectedPortName}" Grid.Column="1" ItemsSource="{Binding PortNames}"/>
                        <TextBlock Text="波特率" Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Foreground="White" Margin="0,10,0,0" />
                        <ComboBox Grid.Row="1" SelectedItem="{Binding SelectedBaudRate}" Grid.Column="1" ItemsSource="{Binding BaudRates}" Margin="0,10,0,0"/>
                        <TextBlock Text="数据位" Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" Foreground="White" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="2" SelectedItem="{Binding SelectedDataBit}" Grid.Column="1" ItemsSource="{Binding DataBits}" Margin="0,10,0,0"/>
                        <TextBlock Text="停止位" Grid.Column="0" Grid.Row="3" VerticalAlignment="Center" Foreground="White" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="3" SelectedItem="{Binding SelectedStopBit}" Grid.Column="1" ItemsSource="{Binding StopBits}" Margin="0,10,0,0"/>
                        <TextBlock Text="校验位" Grid.Column="0" Grid.Row="4" VerticalAlignment="Center" Foreground="White" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="4" SelectedItem="{Binding SelectedParityBit}" Grid.Column="1" ItemsSource="{Binding ParityBits}" Margin="0,10,0,0"/>
                    </Grid>
                    <Button Margin="0,10,0,0" Height="40" Content="保存配置" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Width="120"/>
                </StackPanel>
            </Border>
            <Border Margin="0,10,0,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="登入选项" Foreground="White" FontSize="14" Margin="0,0,10,0"/>
                    <StackPanel >
                        <CheckBox Content="自动登入" Foreground="White" IsChecked="{Binding IsAutoLogin}" Margin="0,10,0,0"/> 
                        <CheckBox Content="启动报警声音提示" Foreground="White" IsChecked="{Binding IsAlarmSound}" Margin="0,10,0,0"/>
                        <CheckBox Content="开启日志调试(Debug)" Foreground="White" IsChecked="{Binding IsDebugModel}" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
