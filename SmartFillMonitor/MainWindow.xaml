<Window x:Class="SmartFillMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartFillMonitor"
        mc:Ignorable="d"
        xmlns:UserControls="clr-namespace:SmartFillMonitor.UserControls"
        Title="MainWindow" Height="450" Width="800"
        Background="Gray">
    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <UserControls:NavigationMenu Grid.Column="0"  Grid.RowSpan="2"/>
        <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource AppBgPannel}" BorderBrush="{StaticResource AppBoardBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="gray" FontSize="14">
                    <Run Text="当前生产批次:"/>
                    <Run Text="{Binding CurrentBatchNo}" FontWeight="SemiBold"/>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
                    <UserControls:StatusIndicator StatusText="PLC在线" IsOnline="{Binding IsPlcConnected}" Margin="0,0,20,0"/>
                    <UserControls:StatusIndicator StatusText="数据库写入中" IsWarning="True" IsOnline="True" Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding CurrentTime}" VerticalAlignment="Center"  FontSize="13" HorizontalAlignment="Center" Margin="0,0,5,0" Foreground="LightBlue"/>
                    <UserControls:StatusLIght State="{Binding MainContent.IndicatorState,Mode=TwoWay}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="" FontSize="16" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding CurrentUserDisplayName}" FontSize="14" Foreground="Gray"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="登入" Style="{StaticResource OutLine }" Command="{Binding LoginCommand}" Margin="0,0,6,0"/>
                        <Button Content="X" Style="{StaticResource OutLine }" Command="{Binding ExitCommand}" Margin="0,0,6,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
           
        </Border>
        <ContentControl Grid.Row="1" Grid.Column="1" Margin="10" Background="{StaticResource AppBgDark}" Content="{Binding MainContent}"/>
        
    </Grid>
</Window>
