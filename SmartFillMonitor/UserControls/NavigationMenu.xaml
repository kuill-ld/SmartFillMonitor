<UserControl x:Class="SmartFillMonitor.UserControls.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="RadioButton" BasedOn="{StaticResource NavItemStyle}"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource NavBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource AppBgPannel}" BorderBrush="{StaticResource AppBoardBrush}" BorderThickness="0,0,0,1" Padding="20">
            <TextBlock Text="SmartFill Monitor"  FontSize="20" Foreground="LightSteelBlue" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <RadioButton GroupName="Navigation" IsChecked="True" Command="{Binding DataContext.NavigateCommand ,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DashBoard">
                <StackPanel Orientation="Horizontal" >
                    <TextBlock Margin="20,1" FontSize="20" Foreground="{StaticResource NavItemForeground}">
                        <Run Text="&#xe620;" FontFamily="{StaticResource IconFont}" />
                        <Run Text="主页监控" />
                    </TextBlock>
                </StackPanel>
            </RadioButton>
            <RadioButton GroupName="Navigation" IsChecked="False" Command="{Binding DataContext.NavigateCommand ,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DashQuery">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="20,10" FontSize="20" Foreground="{StaticResource NavItemForeground}">
                        <Run Text="&#xe634;" FontFamily="{StaticResource IconFont}" />
                        <Run Text="数据查询" />
                    </TextBlock>
                </StackPanel>
            </RadioButton>
            <RadioButton  GroupName="Navigation" IsChecked="False" Command="{Binding DataContext.NavigateCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Logs">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="20,10" FontSize="20" Foreground="{StaticResource NavItemForeground}">
                        <Run Text="&#xe7a0;" FontFamily="{StaticResource IconFont}" />
                        <Run Text="运行日志" />
                    </TextBlock>
                </StackPanel>
            </RadioButton>
            <RadioButton GroupName="Navigation" IsChecked="False" Command="{Binding DataContext.NavigateCommand ,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Alarms">
                <StackPanel Orientation="Horizontal" >
                    <TextBlock Margin="20,10" FontSize="20" Foreground="{StaticResource NavItemForeground}">
                        <Run Text="&#xe602;" FontFamily="{StaticResource IconFont}" />
                        <Run Text="报警管理" />
                    </TextBlock>
                </StackPanel>
            </RadioButton>
            <RadioButton Visibility="{Binding DataContext.IsAdmin,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BooleanToVisibilityConverter}}" GroupName="Navigation" IsChecked="False" Command="{Binding DataContext.NavigateCommand ,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Setting">
                <StackPanel Orientation="Horizontal" >
                    <TextBlock Margin="20,10" FontSize="20" Foreground="{StaticResource NavItemForeground}">
                        <Run Text="&#xe7ba;" FontFamily="{StaticResource IconFont}" />
                        <Run Text="系统设置" />
                    </TextBlock>
                </StackPanel>
            </RadioButton>


        </StackPanel>

    </Grid>
</UserControl>
